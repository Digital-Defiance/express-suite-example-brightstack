# BrightStack Environment Configuration
# Block store path for persistent storage (leave empty for in-memory)
BRIGHTCHAIN_BLOCKSTORE_PATH=
# Comma-separated block sizes in bytes
BRIGHTCHAIN_BLOCKSIZE_BYTES=1048576
# Block store type: disk, azure-blob, s3
BRIGHTCHAIN_BLOCKSTORE_TYPE=disk
# Set to true for in-memory document store (development)
USE_MEMORY_DOCSTORE=true
# Dev database pool name (set for in-memory dev mode, supercedes disk storage)
DEV_DATABASE=example
# Member pool name
MEMBER_POOL_NAME=BrightChain
# SES credentials for email sending
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
# 64 character hex string
JWT_SECRET=0c4f7c1d85563f14d5b6d56b975bfc5e01c1ef0996ae38f6e33c82653c829882
# Dist directories
API_DIST_DIR=/workspaces/digitaldefiance-express-suite-example-brightstack/dist/express-suite-example-brightstack-api
REACT_DIST_DIR=/workspaces/digitaldefiance-express-suite-example-brightstack/dist/express-suite-example-brightstack-react
DEBUG=true
DETAILED_DEBUG=true
EMAIL_DOMAIN=example.com
# Admin and test credentials
ADMIN_ID=""
ADMIN_MNEMONIC=""
ADMIN_ROLE_ID=""
ADMIN_USER_ROLE_ID=""
ADMIN_PASSWORD=""
MEMBER_ID=""
MEMBER_MNEMONIC=""
MEMBER_ROLE_ID=""
MEMBER_PASSWORD=""
MEMBER_USER_ROLE_ID=""
SYSTEM_ID=""
SYSTEM_MNEMONIC=""
SYSTEM_PUBLIC_KEY=""
SYSTEM_ROLE_ID=""
SYSTEM_PASSWORD=""
SYSTEM_USER_ROLE_ID=""
# 64 character hex string
MNEMONIC_ENCRYPTION_KEY=a6606ab3376763c005cc396d93b4fa6545eddd370f3ead14925bf30ce637cdc2
# 64 character hex string
MNEMONIC_HMAC_SECRET=5cc24c6225455ae70e87d84056571a8c3c23c6df53f821ed9464a006d7fde3de
HTTPS_DEV_CERT_DIR=/workspaces/digitaldefiance-express-suite-example-brightstack
HTTPS_DEV_PORT=3443
