# BrightStack Environment Configuration
# Block store path for persistent storage (leave empty for in-memory)
BRIGHTCHAIN_BLOCKSTORE_PATH=
# Comma-separated block sizes in bytes
BRIGHTCHAIN_BLOCKSIZE_BYTES=1048576
# Block store type: disk, azure-blob, s3
BRIGHTCHAIN_BLOCKSTORE_TYPE=disk
# Set to true for in-memory document store (development)
USE_MEMORY_DOCSTORE=true
# Dev database pool name (set for in-memory dev mode, supercedes disk storage)
DEV_DATABASE=test
# Member pool name
MEMBER_POOL_NAME=BrightChain
# SES credentials for email sending
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-west-2
# 64 character hex string
JWT_SECRET=374e4eab7e75ac642ea602de8770e7a210c10901afc2778a3b6bf16fe6a6e6d4
# Dist directories
API_DIST_DIR=/workspaces/digitaldefiance-express-suite-example-brightchain/dist/express-suite-example-brightchain-api
REACT_DIST_DIR=/workspaces/digitaldefiance-express-suite-example-brightchain/dist/express-suite-example-brightchain-react
DEBUG=true
DETAILED_DEBUG=true
# Admin and test credentials
ADMIN_ID=""
ADMIN_MNEMONIC=""
ADMIN_ROLE_ID=""
ADMIN_USER_ROLE_ID=""
ADMIN_PASSWORD=""
MEMBER_ID=""
MEMBER_MNEMONIC=""
MEMBER_ROLE_ID=""
MEMBER_PASSWORD=""
MEMBER_USER_ROLE_ID=""
SYSTEM_ID=""
SYSTEM_MNEMONIC=""
SYSTEM_PUBLIC_KEY=""
SYSTEM_ROLE_ID=""
SYSTEM_PASSWORD=""
SYSTEM_USER_ROLE_ID=""
# 64 character hex string
MNEMONIC_ENCRYPTION_KEY=8cc1e5e51c2efc57d9a7d4df8339b9cc67607ebf7c1011fae1030ce36b3a5ec7
# 64 character hex string
MNEMONIC_HMAC_SECRET=6166292efff662401fd3f063054a7949791c2bd21e018d42c4dada8514140995
HTTPS_DEV_CERT_DIR=/workspaces/digitaldefiance-express-suite-example-brightchain
HTTPS_DEV_PORT=3443
